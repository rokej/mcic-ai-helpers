{
  "_comment": "Local Claude Code CLI fallback only. In Cursor/Ambient, use the host Jira MCP and set MCIC_SKIP_JIRA_MCP_SETUP=1.",
  "mcpServers": {
    "jira-mcp-server": {
      "command": "python3",
      "args": ["-m", "jira_mcp_server.main"],
      "env": {
        "JIRA_SERVER_URL": "https://redhat.atlassian.net",
        "JIRA_ACCESS_TOKEN": "your-api-token",
        "JIRA_EMAIL": "you@redhat.com"
      }
    }
  }
}
